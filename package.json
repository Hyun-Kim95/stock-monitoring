{
  "name": "stock-monitoring",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @stock-monitoring/api\" \"npm run dev -w @stock-monitoring/web\"",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm exec --workspace=@stock-monitoring/db -- prisma generate",
    "db:migrate": "npm exec --workspace=@stock-monitoring/db -- prisma migrate dev",
    "db:push": "npm exec --workspace=@stock-monitoring/db -- prisma db push",
    "db:seed": "npm exec --workspace=@stock-monitoring/db -- prisma db seed",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json && tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p packages/db/tsconfig.json",
    "lint": "eslint apps packages",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.28.0"
  }
}
