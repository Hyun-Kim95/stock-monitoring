{
  "name": "stock-monitoring",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/free-port-predev.mjs",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @stock-monitoring/api\" \"npm run dev -w @stock-monitoring/web\"",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "node scripts/prisma-with-root-env.mjs generate",
    "db:migrate": "node scripts/prisma-with-root-env.mjs migrate dev",
    "db:migrate:deploy": "node scripts/prisma-with-root-env.mjs migrate deploy",
    "db:migrate:resolve": "node scripts/prisma-with-root-env.mjs migrate resolve",
    "db:migrate:resolve:industry-rolled-back": "node scripts/prisma-with-root-env.mjs migrate resolve --rolled-back 20260325093000_add_stock_industry_major_code",
    "db:migrate:resolve:industry-applied": "node scripts/prisma-with-root-env.mjs migrate resolve --applied 20260325093000_add_stock_industry_major_code",
    "db:push": "node scripts/prisma-with-root-env.mjs db push",
    "db:seed": "node scripts/prisma-with-root-env.mjs db seed",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json && tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p packages/db/tsconfig.json",
    "lint": "eslint apps packages",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "@eslint/js": "^9.23.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.28.0"
  }
}
