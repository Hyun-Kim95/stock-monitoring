# PostgreSQL — 로컬 설치 또는 호스팅 DB에 맞게 수정
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/stock_monitoring

# API (apps/api)
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
# 설정 시 관리자 변경(PUT 등) API에 Bearer 필요. 비우면 로컬에서 인증 생략.
ADMIN_API_TOKEN=

# Web — Next도 next.config에서 루트 .env를 읽으므로 여기만 채우면 됨 (별도 apps/web/.env 불필요)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws/quotes
# ADMIN_API_TOKEN 사용 시 동일 값으로 맞출 것 (웹 재시작 후 반영)
NEXT_PUBLIC_ADMIN_TOKEN=

# 한국투자증권 Open API — DB `market_data.provider=kis` 일 때 사용 (없으면 mock)
KIS_APP_KEY=
KIS_APP_SECRET=
# 비우면 모의투자 REST 베이스 (실전: https://openapi.koreainvestment.com:9443)
KIS_REST_BASE_URL=
# 현재가 TR_ID (기본 FHKST01010100, 문서와 다르면 여기서 교체)
KIS_TR_ID_PRICE=
# inquire-price 종목 간 대기(ms). 비우면 400. EGW00201(초당 건수 초과) 시 600~1000 등으로 상향
KIS_QUOTE_REQUEST_GAP_MS=

# 네이버 검색 API(뉴스) — 앱에「검색」API 사용 추가 필수. 미설정 시 목 뉴스
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
