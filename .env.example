# PostgreSQL (docker-compose 기본값과 맞춤)
DATABASE_URL=postgresql://stock:stock@localhost:5432/stock_monitoring

# API (apps/api)
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
# 설정 시 관리자 변경 API에 Bearer 필요. 비우면 로컬에서 인증 생략.
ADMIN_API_TOKEN=

# Web (apps/web — .env.local 권장)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws/quotes
# 브라우저에서 관리자 요청 시 (또는 localStorage.adminToken)
NEXT_PUBLIC_ADMIN_TOKEN=

# 한국투자증권 Open API — DB `market_data.provider=kis` 일 때 사용 (없으면 mock)
KIS_APP_KEY=
KIS_APP_SECRET=
# 비우면 모의투자 REST 베이스 (실전: https://openapi.koreainvestment.com:9443)
KIS_REST_BASE_URL=
# 현재가 TR_ID (기본 FHKST01010100, 문서와 다르면 여기서 교체)
KIS_TR_ID_PRICE=

# 네이버 검색 API (뉴스) — Client ID/Secret 없으면 목 뉴스
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
