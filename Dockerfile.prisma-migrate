# Railway(또는 CI) 전용: `npm run db:migrate:deploy` 한 번 실행 후 종료
# 서비스 설정: Root Directory `/`, Dockerfile 경로 `Dockerfile.prisma-migrate`,
# Variables에 DATABASE_URL (Postgres 서비스 참조 변수) 필수.
FROM node:20-bookworm-slim
WORKDIR /app

COPY package.json package-lock.json ./
COPY packages ./packages
COPY apps ./apps
COPY scripts ./scripts

RUN npm ci

ENV NODE_ENV=production
CMD ["npm", "run", "db:migrate:deploy"]
